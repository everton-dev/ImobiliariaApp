# OS
.DS_Store
Thumbs.db
*.tmp
*.swp

# IDE
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# ─── Frontend (Angular) ───────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/coverage/
frontend/.env
frontend/.env.*

# Owner's runtime config — NOT committed; only config.example.json is committed
frontend/src/assets/config.json

# Test outputs
frontend/test-results/
frontend/playwright-report/
frontend/blob-report/

# ─── Backend (.NET) ───────────────────────────────────────────────────────────
backend/bin/
backend/obj/
backend/**/bin/
backend/**/obj/
backend/**/*.user

# Azure Functions local secrets — NEVER commit
backend/**/local.settings.json

# EF Core migrations (intentionally excluded until first schema needed)
# backend/**/Migrations/

# NuGet
*.nupkg
*.snupkg

# ─── General build artifacts ──────────────────────────────────────────────────
*.log
*.out
